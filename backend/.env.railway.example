# ─── Copy-paste ini ke Railway dashboard → Variables ─────────────────────────
# JANGAN isi file ini dengan nilai asli! Ini hanya template.
# Isi nilainya langsung di Railway dashboard.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=GachaWaifu
APP_ENV=production
APP_KEY=                        # generate dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=                        # akan diisi otomatis Railway, contoh: https://xxx.railway.app

# ─── Database ─────────────────────────────────────────────────────────────────
# Pilih SQLite (simple, cocok untuk demo) ATAU PostgreSQL (disarankan):
#
# Opsi A: SQLite (simpel, tapi data hilang kalau Railway restart container)
DB_CONNECTION=sqlite
#
# Opsi B: PostgreSQL via Railway (lebih stabil, data persist)
# Tambahkan plugin "PostgreSQL" di Railway, lalu variabel ini akan auto-terisi:
# DB_CONNECTION=pgsql
# DB_URL=                       # Railway auto-isi ini (DATABASE_URL)

# ─── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=                   # URL Vercel kamu, contoh: https://gacha-waifu-tawny.vercel.app

# ─── AI (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=                   # API key Groq kamu

# ─── Misc ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=error
BCRYPT_ROUNDS=12
